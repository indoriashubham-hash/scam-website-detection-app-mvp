# Copy to .env for local overrides. docker-compose sets sane defaults already.
DATABASE_URL=postgresql+asyncpg://wri:wri@postgres:5432/wri
REDIS_URL=redis://redis:6379/0

S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=wri
S3_SECRET_KEY=wri-secret
S3_BUCKET=wri-evidence
S3_PUBLIC_BASE=http://localhost:9000/wri-evidence

# Crawl knobs
CRAWL_MAX_PAGES=15
CRAWL_PER_HOST_RPS=1.0
CRAWL_PAGE_TIMEOUT_MS=30000
CRAWL_NAV_IDLE_MS=15000
CRAWL_USER_AGENT=WebsiteRiskInvestigator/0.1 (+https://example.com/bot)

# Feature flags
ENABLE_PLAYWRIGHT=true
